@model IEnumerable<HostelManagement.Models.Room>


<h2>Room List</h2>


<table class="table table-bordered">


    <tr>

        <th>Room No</th>

        <th>Room Type</th>

        <th>Capacity</th>

        <th>Status</th>

        <th>Action</th>

    </tr>



    @foreach (var item in Model)
    {

        <tr>


            <td>@item.RoomNo</td>


            <td>@item.RoomType</td>


            <td>@item.Capacity</td>


            <td>@item.Status</td>



            <td>


                <a asp-action="EditRoom"
                   asp-route-id="@item.Room_id"
                   class="btn btn-warning">

                    Edit

                </a>



                <a asp-action="DeleteRoom"
                   asp-route-id="@item.Room_id"
                   class="btn btn-danger"
                   onclick="return confirm('Delete this room?')">

                    Delete

                </a>



                <a asp-controller="Allocation"
                   asp-action="AddAllocation"
                   class="btn btn-success">

                    Allocate

                </a>


            </td>


        </tr>

    }


</table>



<a asp-action="AddRoom"
   class="btn btn-primary">

    Add New Room

</a>